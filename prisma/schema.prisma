generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  logoUrl   String?
  
  // Standings data
  played    Int      @default(0)
  won       Int      @default(0)
  drawn     Int      @default(0)
  lost      Int      @default(0)
  gf        Int      @default(0) // Goals For
  ga        Int      @default(0) // Goals Against
  points    Int      @default(0)

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
}

model Match {
  id            String   @id @default(cuid())
  homeTeamId    String
  awayTeamId    String
  homeScore     Int?
  awayScore     Int?
  matchDate     DateTime
  status        String   @default("SCHEDULED") // SCHEDULED, FINISHED

  // Statistics
  possessionHome Int?
  possessionAway Int?
  shotsHome      Int?
  shotsAway      Int?
  yellowCardsHome Int?
  yellowCardsAway Int?
  redCardsHome    Int?
  redCardsAway    Int?

  homeTeam Team @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team @relation("AwayTeam", fields: [awayTeamId], references: [id])
  
  scorers Scorer[]
}

model Scorer {
  id        String @id @default(cuid())
  matchId   String
  playerName String
  minute     Int
  teamId     String // To identify which team scored

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}
