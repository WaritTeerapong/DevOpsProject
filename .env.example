# Database (PostgreSQL)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ctf_db
# For local dev without Docker for Next.js
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ctf_db?schema=public
# For running inside Docker
# DATABASE_URL=postgresql://postgres:postgres@db:5432/ctf_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379
# For running inside Docker
# REDIS_URL=redis://redis:6379

# Authentication (JWT)
JWT_SECRET=supersecret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
CALLBACK_URL=http://localhost:3000/auth/google/callback

# Application
PORT=3000
NODE_ENV=development
